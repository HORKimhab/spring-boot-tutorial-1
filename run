#!/usr/bin/env bash

PORT=8081

# ./mvnw spring-boot:run \
#   -Dspring-boot.run.arguments="--server.port=$PORT"

# Forward all arguments to mvnw
# ./mvnw "$@" spring-boot:run \
#   -Dspring-boot.run.arguments="--server.port=$PORT"

# Check if the first argument is 'clean'
if [[ "$1" == "clean" ]]; then
    MVN_CMD="./mvnw clean spring-boot:run"
    # Shift so any additional args go to mvnw
    shift
elif [[ "$1" == "hard-clean" ]]; then
    # ← clears Maven target + Spring devtools cache
    echo "🧹 Hard cleaning..."
    rm -rf target/
    rm -rf ~/.m2/repository/com/hkimhab/  # ← your group id
    MVN_CMD="./mvnw clean spring-boot:run"
    shift
else
    MVN_CMD="./mvnw spring-boot:run"
fi

# Forward any remaining arguments and set server port
$MVN_CMD "$@" -Dspring-boot.run.arguments="--server.port=$PORT"